# ─────────────────────────────────────────────────────────────────────────────
#  assistant — root .gitignore
# ─────────────────────────────────────────────────────────────────────────────

# ── Claude local settings ─────────────────────────────────────────────────────
.claude/settings.local.json

# ── Local secrets / env files ────────────────────────────────────────────────
.env
.env.*
*.local

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
env/
*.egg-info/

# ── OS / editor noise ─────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
.idea/
.vscode/settings.json
*.swp
*.swo

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Packaging output ──────────────────────────────────────────────────────────
dist/
release/
*.zip
