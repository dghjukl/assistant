# ─────────────────────────────────────────────────────────────────────────────
#  EOS — .gitignore
#  Keeps credentials, model binaries, runtime state, and generated files
#  out of version control.  Example/template files are still tracked.
# ─────────────────────────────────────────────────────────────────────────────

# ── Credentials (real files — example templates ARE tracked) ─────────────────
AI personal files/*
!AI personal files/*.example.txt
!AI personal files/*.example.json
config/google/*.json
!config/google/README.md

# ── Runtime auth tokens ───────────────────────────────────────────────────────
data/google_token.json
data/admin_token.txt

# ── Runtime state (generated at first run) ────────────────────────────────────
data/entity_state.db
data/entity_state.db-shm
data/entity_state.db-wal
data/documents.db
data/event_journal.db
data/scheduler.db
data/entity_lifecycle.json
data/session_continuity.json
data/uploads/
data/shutdown_ledger.json
data/audit.db
data/memory_store/
data/backups/
data/workspace/
data/computer_use/

# ── Worldview runtime files (generated by extraction pipeline) ────────────────
data/worldview/profile.md
data/worldview/extraction_log.json
data/worldview/sources/
# Keep the README
!data/worldview/README.md

# ── Embedding model (bundled separately, not in git) ──────────────────────────
models/embedding/

# ── Model binaries ────────────────────────────────────────────────────────────
models/primary/*.gguf
models/vision/*.gguf
models/tool/*.gguf
models/thinking/*.gguf
models/creativity/*.gguf
models/stt/*.bin
models/tts/*.onnx
models/tts/*.onnx.json
models/utility/*.gguf

# ── Downloaded binaries / engines ─────────────────────────────────────────────
llama-CPU/
llama-b8149-bin-win-cuda-13.1-x64/
Piper/

# ── Local secrets / env files ────────────────────────────────────────────────
.env
.env.*
*.local

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
env/
*.egg-info/

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Claude local settings ─────────────────────────────────────────────────────
.claude/settings.local.json

# ── OS / editor noise ─────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
.idea/
.vscode/settings.json
*.swp
*.swo

# ── Packaging output ──────────────────────────────────────────────────────────
dist/
release/
*.zip
