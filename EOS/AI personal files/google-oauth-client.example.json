{
  "installed": {
    "client_id": "YOUR_CLIENT_ID.apps.googleusercontent.com",
    "project_id": "your-project-id",
    "auth_uri": "https://accounts.google.com/o/oauth2/auth",
    "token_uri": "https://oauth2.googleapis.com/token",
    "auth_provider_x509_cert_url": "https://www.googleapis.com/oauth2/v1/certs",
    "client_secret": "YOUR_CLIENT_SECRET",
    "redirect_uris": ["http://localhost"]
  }
}

// ─────────────────────────────────────────────────────────────────────────────
//  How to get your Google OAuth client secret:
//
//  1. Go to https://console.cloud.google.com/
//  2. Create a new project (or select an existing one)
//  3. Enable these APIs (APIs & Services → Library):
//       - Google Calendar API
//       - Gmail API
//       - Google Drive API
//  4. Go to APIs & Services → Credentials
//  5. Create Credentials → OAuth 2.0 Client ID
//       - Application type: Desktop app
//       - Name: EOS (or anything)
//  6. Download the JSON file
//  7. Rename it to match the pattern:  client_secret_XXXX.apps.googleusercontent.com.json
//     (or any name matching client_secret_*.json)
//  8. Place it in this folder:  AI personal files/
//
//  On first run with Google enabled, EOS will open a browser window for you
//  to authorize access. After that, a token is saved to data/google_token.json
//  and re-authorization is not needed unless the token expires.
//
//  In config.*.json, set:
//    "google": { "enabled": true, ... }
//
//  Set "enabled": false if you are not using Google integrations.
// ─────────────────────────────────────────────────────────────────────────────
