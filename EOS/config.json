{
  "_comment": "EOS canonical configuration. This file defines the full intended system; startup scripts decide which backends to launch, and runtime discovery handles fallback.",
  "servers": {
    "primary": {
      "_role": "Conscious mind. The only model that speaks, reasons, holds identity, and makes decisions.",
      "binary_gpu": "llama-b8149-bin-win-cuda-13.1-x64/llama-server.exe",
      "binary_cpu": "llama-CPU/llama-server.exe",
      "model_path": "models/primary/",
      "host": "127.0.0.1",
      "port": 8080,
      "n_gpu_layers": 99,
      "context_size": 16384,
      "parallel": 1,
      "required": true,
      "enabled": true,
      "cpu_n_gpu_layers": 0,
      "gpu_n_gpu_layers": 99
    },
    "vision": {
      "_role": "Perception only. Routes image inputs through VisionObservation schema. Output injected as context into primary. Does NOT converse.",
      "binary_gpu": "llama-b8149-bin-win-cuda-13.1-x64/llama-server.exe",
      "model_path": "models/vision/",
      "mmproj_path": "models/vision/",
      "host": "127.0.0.1",
      "port": 8081,
      "n_gpu_layers": 99,
      "context_size": 2048,
      "parallel": 1,
      "required": false,
      "enabled": true,
      "cpu_n_gpu_layers": 0,
      "gpu_n_gpu_layers": 99
    },
    "tool": {
      "_role": "Extracts structured function calls from primary output. Does not generate responses.",
      "binary_cpu": "llama-CPU/llama-server.exe",
      "model_path": "models/tool/",
      "host": "127.0.0.1",
      "port": 8082,
      "n_gpu_layers": 0,
      "context_size": 2048,
      "parallel": 1,
      "required": false,
      "enabled": true,
      "cpu_n_gpu_layers": 0,
      "binary_gpu": "llama-b8149-bin-win-cuda-13.1-x64/llama-server.exe",
      "gpu_n_gpu_layers": 99
    },
    "thinking": {
      "_role": "Background thinking worker. Non-blocking. Dispatched to by idle cognition, initiative, investigation, identity eval. NOT an escalation target \u2014 primary uses /think for inline reasoning.",
      "binary_cpu": "llama-CPU/llama-server.exe",
      "model_path": "models/thinking/",
      "host": "127.0.0.1",
      "port": 8083,
      "n_gpu_layers": 0,
      "context_size": 2048,
      "parallel": 1,
      "required": false,
      "enabled": true,
      "cpu_n_gpu_layers": 0,
      "binary_gpu": "llama-b8149-bin-win-cuda-13.1-x64/llama-server.exe",
      "gpu_n_gpu_layers": 99
    },
    "creativity": {
      "_role": "Controlled divergence subsystem. Advisory only \u2014 proposes alternate interpretations, reframes, analogies, non-obvious solution paths, and ideation. Does not decide, authorize, or override. Degrades gracefully if absent.",
      "binary_cpu": "llama-CPU/llama-server.exe",
      "model_path": "models/creativity/",
      "host": "127.0.0.1",
      "port": 8084,
      "n_gpu_layers": 0,
      "context_size": 2048,
      "parallel": 1,
      "required": false,
      "enabled": true,
      "cpu_n_gpu_layers": 0,
      "binary_gpu": "llama-b8149-bin-win-cuda-13.1-x64/llama-server.exe",
      "gpu_n_gpu_layers": 99
    }
  },
  "creativity": {
    "_comment": "Creativity subsystem parameters. Runtime discovery determines whether the helper is currently available.",
    "injection_frequency": "medium",
    "_injection_frequency_options": [
      "off",
      "low",
      "medium",
      "high"
    ],
    "intensity": "balanced",
    "_intensity_options": [
      "conservative",
      "balanced",
      "exploratory",
      "aggressive"
    ],
    "invocation_domains": {
      "reasoning_assistance": true,
      "autonomous_idle": true,
      "explanation_generation": true,
      "brainstorming_design": true,
      "stuck_state_recovery": true
    },
    "output_structure_mode": "structured",
    "_output_structure_options": [
      "structured",
      "semi-structured",
      "loose"
    ],
    "advanced": {
      "_comment": "Advanced overrides. When set, these take precedence over preset intensity modes.",
      "temperature": null,
      "top_p": null,
      "top_k": null,
      "max_tokens": null,
      "response_format_template": null
    },
    "_intensity_presets": {
      "conservative": {
        "temperature": 0.6,
        "top_p": 0.85,
        "top_k": 40
      },
      "balanced": {
        "temperature": 0.85,
        "top_p": 0.92,
        "top_k": 60
      },
      "exploratory": {
        "temperature": 1.05,
        "top_p": 0.96,
        "top_k": 80
      },
      "aggressive": {
        "temperature": 1.3,
        "top_p": 0.99,
        "top_k": 100
      }
    },
    "enabled": true
  },
  "primary": {
    "is_multimodal": false,
    "requires_mmproj": false,
    "mmproj_path": null
  },
  "webui": {
    "host": "127.0.0.1",
    "port": 7860
  },
  "access_tiers": {
    "_comment": "Per-origin access policies. Overrides can be set at runtime from the Access Tiers admin panel (persisted to data/access_tiers.json).",
    "localhost": {
      "enabled": true,
      "chat_enabled": true,
      "admin_enabled": true,
      "require_auth": false,
      "rate_limit_rpm": 0,
      "rate_limit_burst": 0,
      "session_ttl_sec": 86400
    },
    "lan": {
      "enabled": true,
      "chat_enabled": true,
      "admin_enabled": true,
      "require_auth": true,
      "rate_limit_rpm": 60,
      "rate_limit_burst": 15,
      "session_ttl_sec": 86400
    },
    "external": {
      "enabled": false,
      "chat_enabled": false,
      "admin_enabled": false,
      "require_auth": true,
      "rate_limit_rpm": 20,
      "rate_limit_burst": 5,
      "session_ttl_sec": 3600
    }
  },
  "retrieval": {
    "embed_model": "models/embedding/all-MiniLM-L6-v2",
    "chroma_path": "data/memory_store",
    "collection": "entity_memory",
    "top_k": 5
  },
  "db_path": "data/entity_state.db",
  "qwen3": {
    "temperature": 0.7,
    "top_p": 0.9,
    "max_tokens": 2048,
    "think_token": "/think",
    "no_think_token": "/no_think"
  },
  "identity": {
    "eval_every_n_interactions": 20,
    "stability_threshold": 0.85,
    "naming_requires_stable": 6
  },
  "autonomy_defaults": {
    "perception": true,
    "cognition": true,
    "action": true,
    "initiative": true
  },
  "cognition": {
    "enable_cognition_trace": true,
    "turn_ring_size": 200,
    "reflection_ring_size": 100,
    "state_ring_size": 100
  },
  "stt": {
    "model_path": "models/stt/ggml-small.en-q8_0.bin",
    "sample_rate": 16000,
    "channels": 1,
    "chunk_ms": 30,
    "silence_ms": 800,
    "language": "en",
    "fw_model": "small.en",
    "fw_device": "cpu",
    "fw_compute": "int8"
  },
  "tts": {
    "binary": "Piper/piper/piper.exe",
    "model_path": "models/tts/en_US-amy-medium.onnx",
    "sample_rate": 22050,
    "speaker_id": 0
  },
  "discord": {
    "enabled": true,
    "credential_file": "AI personal files/Discord.txt",
    "respond_only_to_mentions": true,
    "ignore_bots": true
  },
  "google": {
    "enabled": true,
    "client_secret_path": "AI personal files/client_secret_*.json",
    "token_path": "data/google_token.json",
    "calendar_enabled": true,
    "gmail_enabled": true,
    "gmail_send_enabled": true,
    "drive_enabled": true
  },
  "workspace_tools": {
    "_comment": "Sandboxed workspace available to the entity as its persistent file environment.",
    "enabled": true,
    "workspace_root": "data/workspace",
    "allow_delete": true,
    "allow_exec": true
  },
  "worldview": {
    "_comment": "Passive partner orientation subsystem. Sources are processed on demand (never automatically). Receiving a source document requires no acknowledgment. The profile shapes interpretation, not conversational content.",
    "enabled": true,
    "worldview_path": "data/worldview",
    "max_profile_lines_in_prompt": 10
  },
  "backup": {
    "_comment": "Automatic state snapshots. Covers DB, vector memory, workspace, and JSON state files.",
    "backup_path": "data/backups",
    "max_backups": 10,
    "auto_backup_interval_hours": 24
  },
  "computer_use": {
    "_comment": "Supervised computer-use subsystem. Layered access: mode \u2192 shortcut allowlist \u2192 per-app action policy.",
    "_doc": "Enabling this does NOT grant the entity unrestricted computer access. The entity may only use applications present in approved_shortcuts_path, and only the actions listed in app_policy_path. The operator sets the mode. Halt is always available.",
    "enabled": true,
    "default_mode": "command_only",
    "approved_shortcuts_path": "data/computer_use/approved_shortcuts",
    "app_policy_path": "data/computer_use/app_policy.json",
    "decision_ring_size": 200,
    "_modes": {
      "off": "No computer use permitted.",
      "command_only": "Approved apps only, for direct user-requested tasks.",
      "supervised_session": "Approved apps with bounded continuation while operator supervises."
    }
  },
  "toolpacks": {
    "_comment": "All packs are loaded into the registry at startup. The admin panel controls which are enabled. Add pack names here to make them available to the entity.",
    "enabled": true,
    "packs": [
      "deterministic_tools",
      "text_tools",
      "diff_tools",
      "event_journal_tools",
      "web_tools",
      "workspace_tools",
      "network_tools",
      "http_diag_tools",
      "fs_tools",
      "git_tools",
      "package_tools",
      "telemetry_tools",
      "ingestion_tools",
      "ca_tools",
      "notifications_tools",
      "google_tools",
      "scheduler_tools",
      "process_tools",
      "recovery_tools",
      "secrets_tools",
      "service_control_tools",
      "system_cmd_tools"
    ],
    "required_packs": [],
    "notifications_tools": {
      "discord_credential_file": "AI personal files/Discord.txt"
    }
  },
  "deployment_mode": "standard",
  "on_demand": {
    "_comment": "Helper servers (tool, thinking, creativity) start only when the primary model needs them and shut down after idle_ttl_seconds of inactivity.",
    "idle_ttl_seconds": 300
  }
}
