    "output_structure_mode": "structured",
    "_output_structure_options": [
      "structured",
      "semi-structured",
      "loose"
    ],
    "advanced": {
      "_comment": "Advanced overrides. When set, these take precedence over preset intensity modes.",
      "temperature": null,
      "top_p": null,
      "top_k": null,
      "max_tokens": null,
