{
  "_comment": "EOS Base Mode — Primary (GPU) + Tool (CPU) only. No thinking, no creativity, no vision. Minimum footprint; fastest startup.",
  "deployment_mode": "standard",

  "servers": {
    "primary": {
      "_role": "Conscious mind. The only model that speaks, reasons, holds identity, and makes decisions.",
      "enabled": true,
      "binary_gpu": "llama-b8149-bin-win-cuda-13.1-x64/llama-server.exe",
      "binary_cpu": "llama-CPU/llama-server.exe",
      "model_path": "models/primary/",
      "host": "127.0.0.1",
      "port": 8080,
      "n_gpu_layers": 99,
      "context_size": 8192,
      "required": true
    },
    "vision": {
      "_role": "Perception only. Not active in this profile.",
      "enabled": false,
      "binary_gpu": "llama-b8149-bin-win-cuda-13.1-x64/llama-server.exe",
      "model_path": "models/vision/",
      "mmproj_path": "models/vision/",
      "host": "127.0.0.1",
      "port": 8081,
      "n_gpu_layers": 99,
      "context_size": 4096,
      "required": false
    },
    "tool": {
      "_role": "Extracts structured function calls from Qwen3 output. Does not generate responses.",
      "enabled": true,
      "binary_cpu": "llama-CPU/llama-server.exe",
      "model_path": "models/tool/",
      "host": "127.0.0.1",
      "port": 8082,
      "n_gpu_layers": 0,
      "context_size": 4096,
      "required": false
    },
    "thinking": {
      "_role": "Background thinking worker. Not active in this profile.",
      "enabled": false,
      "binary_cpu": "llama-CPU/llama-server.exe",
      "model_path": "models/thinking/",
      "host": "127.0.0.1",
      "port": 8083,
      "n_gpu_layers": 0,
      "context_size": 4096,
      "required": false
    },
    "creativity": {
      "_role": "Controlled divergence subsystem. Not active in this profile.",
      "enabled": false,
      "binary_cpu": "llama-CPU/llama-server.exe",
      "model_path": "models/creativity/",
      "host": "127.0.0.1",
      "port": 8084,
      "n_gpu_layers": 0,
      "context_size": 4096,
      "required": false
    }
  },

  "creativity": {
    "_comment": "Creativity subsystem not active in base profile.",
    "enabled": false,
    "injection_frequency": "medium",
    "_injection_frequency_options": ["off", "low", "medium", "high"],
    "intensity": "balanced",
    "_intensity_options": ["conservative", "balanced", "exploratory", "aggressive"],
    "invocation_domains": {
      "reasoning_assistance": true,
      "autonomous_idle": false,
      "explanation_generation": true,
      "brainstorming_design": true,
      "stuck_state_recovery": true
    },
    "output_structure_mode": "structured",
    "_output_structure_options": ["structured", "semi-structured", "loose"],
    "advanced": {
      "_comment": "Advanced overrides. When set, these take precedence over preset intensity modes.",
      "temperature": null,
      "top_p": null,
      "top_k": null,
      "max_tokens": null,
      "response_format_template": null
    },
    "_intensity_presets": {
      "conservative":  {"temperature": 0.6,  "top_p": 0.85, "top_k": 40},
      "balanced":      {"temperature": 0.85, "top_p": 0.92, "top_k": 60},
      "exploratory":   {"temperature": 1.05, "top_p": 0.96, "top_k": 80},
      "aggressive":    {"temperature": 1.3,  "top_p": 0.99, "top_k": 100}
    }
  },

  "primary": {
    "is_multimodal": false,
    "requires_mmproj": false,
    "mmproj_path": null
  },

  "webui": {
    "host": "127.0.0.1",
    "port": 7860
  },
  "access_tiers": {
    "_comment": "Per-origin access policies. Overrides can be set at runtime from the Access Tiers admin panel.",
    "localhost": {
      "enabled": true,
      "chat_enabled": true,
      "admin_enabled": true,
      "require_auth": false,
      "rate_limit_rpm": 0,
      "rate_limit_burst": 0,
      "session_ttl_sec": 86400
    },
    "lan": {
      "enabled": true,
      "chat_enabled": true,
      "admin_enabled": true,
      "require_auth": true,
      "rate_limit_rpm": 60,
      "rate_limit_burst": 15,
      "session_ttl_sec": 86400
    },
    "external": {
      "enabled": false,
      "chat_enabled": false,
      "admin_enabled": false,
      "require_auth": true,
      "rate_limit_rpm": 20,
      "rate_limit_burst": 5,
      "session_ttl_sec": 3600
    }
  },

  "retrieval": {
    "embed_model": "models/embedding/all-MiniLM-L6-v2",
    "chroma_path": "data/memory_store",
    "collection": "entity_memory",
    "top_k": 5
  },

  "db_path": "data/entity_state.db",

  "qwen3": {
    "temperature": 0.7,
    "top_p": 0.9,
    "max_tokens": 2048,
    "think_token": "/think",
    "no_think_token": "/no_think"
  },

  "identity": {
    "eval_every_n_interactions": 20,
    "stability_threshold": 0.85,
    "naming_requires_stable": 6
  },

  "autonomy_defaults": {
    "perception": true,
    "cognition": true,
    "action": false,
    "initiative": false
  },

  "cognition": {
    "enable_cognition_trace": true,
    "turn_ring_size": 200,
    "reflection_ring_size": 100,
    "state_ring_size": 100,
    "relational_interval_turns": 40,
    "relational_interval_seconds": 1800
  },

  "idle_cognition": {
    "_comment": "Base mode — minimal footprint. Idle cognition fires rarely; no thinking server available so uses primary model directly.",
    "enabled": true,
    "resting_threshold_hours": 3.0,
    "drifting_threshold_hours": 8.0,
    "deep_threshold_hours": 24.0,
    "resting_fire_prob": 0.15,
    "drifting_fire_prob": 0.30,
    "deep_fire_prob": 0.55,
    "min_gap_hours": 2.0,
    "max_cognitions_per_day": 3,
    "memory_context_count": 4,
    "max_tokens": 140,
    "temperature": 0.80
  },

  "stt": {
    "model_path": "models/stt/ggml-small.en-q8_0.bin",
    "sample_rate": 16000,
    "channels": 1,
    "chunk_ms": 30,
    "silence_ms": 800,
    "language": "en",
    "fw_model": "small.en",
    "fw_device": "cpu",
    "fw_compute": "int8"
  },

  "tts": {
    "binary": "Piper/piper/piper.exe",
    "model_path": "models/tts/en_US-amy-medium.onnx",
    "sample_rate": 22050,
    "speaker_id": 0
  },

  "discord": {
    "enabled": true,
    "credential_file": "AI personal files/Discord.txt",
    "respond_only_to_mentions": true,
    "ignore_bots": true
  },

  "google": {
    "enabled": true,
    "client_secret_path": "AI personal files/client_secret_*.json",
    "token_path": "data/google_token.json",
    "calendar_enabled": true,
    "gmail_enabled": true,
    "drive_enabled": true
  },

  "workspace_tools": {
    "_comment": "Sandboxed workspace available to the entity as its persistent file environment.",
    "enabled": true,
    "workspace_root": "data/workspace",
    "allow_delete": false,
    "allow_exec": false
  },

  "worldview": {
    "_comment": "Passive partner orientation subsystem. Sources are processed on demand (never automatically). Receiving a source document requires no acknowledgment. The profile shapes interpretation, not conversational content.",
    "enabled": true,
    "worldview_path": "data/worldview",
    "max_profile_lines_in_prompt": 10
  },

  "backup": {
    "_comment": "Automatic state snapshots. Covers DB, vector memory, workspace, and JSON state files.",
    "backup_path": "data/backups",
    "max_backups": 10,
    "auto_backup_interval_hours": 24
  },

  "computer_use": {
    "_comment": "Supervised computer-use subsystem. Layered access: mode → shortcut allowlist → per-app action policy.",
    "_doc": "Enabling this does NOT grant the entity unrestricted computer access. The entity may only use applications present in approved_shortcuts_path, and only the actions listed in app_policy_path. The operator sets the mode. Halt is always available.",
    "enabled": false,
    "default_mode": "off",
    "approved_shortcuts_path": "data/computer_use/approved_shortcuts",
    "app_policy_path": "data/computer_use/app_policy.json",
    "decision_ring_size": 200,
    "_modes": {
      "off": "No computer use permitted.",
      "command_only": "Approved apps only, for direct user-requested tasks.",
      "supervised_session": "Approved apps with bounded continuation while operator supervises."
    }
  },

  "toolpacks": {
    "_comment": "All packs are loaded into the registry at startup. The admin panel controls which are enabled. Add pack names here to make them available to the entity.",
    "enabled": true,
    "packs": [
      "deterministic_tools",
      "text_tools",
      "diff_tools",
      "event_journal_tools",
      "web_tools",
      "workspace_tools",
      "network_tools",
      "http_diag_tools",
      "fs_tools",
      "git_tools",
      "package_tools",
      "telemetry_tools",
      "ingestion_tools",
      "ca_tools",
      "notifications_tools",
      "google_tools",
      "scheduler_tools",
      "process_tools",
      "recovery_tools",
      "secrets_tools",
      "service_control_tools",
      "system_cmd_tools"
    ],
    "required_packs": [],
    "notifications_tools": {
      "discord_credential_file": "AI personal files/Discord.txt"
    }
  }
}
