{
  "_comment": "EOS Vision Mode — Primary GPU + Vision GPU + Tool + Thinking + optional Creativity.",
  "deployment_mode": "vision",
  "servers": {
    "primary": {
      "_role": "Conscious mind. The only model that speaks, reasons, holds identity, and makes decisions.",
      "enabled": true,
      "binary_gpu": "llama-b8149-bin-win-cuda-13.1-x64/llama-server.exe",
      "binary_cpu": "llama-CPU/llama-server.exe",
      "model_path": "models/primary/",
      "host": "127.0.0.1",
      "port": 8080,
      "n_gpu_layers": 99,
      "context_size": 8192,
      "required": true,
      "residency": "resident",
      "activation_mode": "persistent"
    },
    "vision": {
      "_role": "Perception only. Routes image inputs through VisionObservation schema. Output injected as context into primary. Does NOT converse.",
      "enabled": true,
      "binary_gpu": "llama-b8149-bin-win-cuda-13.1-x64/llama-server.exe",
      "model_path": "models/vision/",
      "mmproj_path": "models/vision/",
      "host": "127.0.0.1",
      "port": 8081,
      "n_gpu_layers": 99,
      "context_size": 4096,
      "required": true,
      "_required_note": "Vision mode without a ready vision server is an ERROR STATE, not degraded mode.",
      "residency": "resident",
      "activation_mode": "persistent"
    },
    "tool": {
      "_role": "Extracts structured function calls from Qwen3 output. Does not generate responses.",
      "enabled": true,
      "binary_cpu": "llama-CPU/llama-server.exe",
      "model_path": "models/tool/",
      "host": "127.0.0.1",
      "port": 8082,
      "n_gpu_layers": 0,
      "context_size": 4096,
      "required": false,
      "residency": "resident",
      "activation_mode": "persistent"
    },
    "thinking": {
      "_role": "Background thinking worker. Non-blocking. Dispatched to by idle cognition, initiative, investigation, identity eval. NOT an escalation target.",
      "enabled": true,
      "binary_cpu": "llama-CPU/llama-server.exe",
      "model_path": "models/thinking/",
      "host": "127.0.0.1",
      "port": 8083,
      "n_gpu_layers": 0,
      "context_size": 4096,
      "required": false,
      "residency": "auxiliary",
      "activation_mode": "on_demand",
      "idle_timeout_seconds": 420,
      "cooldown_seconds": 120,
      "min_uptime_seconds": 90
    },
    "creativity": {
      "_role": "Controlled divergence subsystem. Advisory only — proposes alternate interpretations, reframes, analogies, non-obvious solution paths, and ideation. Does not decide, authorize, or override. Optional at runtime; system degrades gracefully if absent.",
      "enabled": false,
      "binary_cpu": "llama-CPU/llama-server.exe",
      "model_path": "models/creativity/",
      "host": "127.0.0.1",
      "port": 8084,
      "n_gpu_layers": 0,
      "context_size": 4096,
      "required": false,
      "residency": "auxiliary",
      "activation_mode": "on_demand",
      "idle_timeout_seconds": 420,
      "cooldown_seconds": 120,
      "min_uptime_seconds": 90
    }
  },
  "creativity": {
    "_comment": "Creativity subsystem — first-class cognitive service for controlled divergence. Advisory only; optional at runtime. All settings are hot-reloadable where possible. If the server is unavailable, all settings are safely ignored.",
    "enabled": false,
    "injection_frequency": "medium",
    "_injection_frequency_options": [
      "off",
      "low",
      "medium",
      "high"
    ],
    "intensity": "balanced",
    "_intensity_options": [
      "conservative",
      "balanced",
      "exploratory",
      "aggressive"
    ],
    "invocation_domains": {
      "reasoning_assistance": true,
      "autonomous_idle": false,
      "explanation_generation": true,
      "brainstorming_design": true,
      "stuck_state_recovery": true
    },
    "output_structure_mode": "structured",
    "_output_structure_options": [
      "structured",
      "semi-structured",
      "loose"
    ],
    "advanced": {
      "_comment": "Advanced overrides. When set, these take precedence over preset intensity modes.",
      "temperature": null,
      "top_p": null,
      "top_k": null,
      "max_tokens": null,
      "response_format_template": null
    },
    "_intensity_presets": {
      "conservative": {
        "temperature": 0.6,
        "top_p": 0.85,
        "top_k": 40
      },
      "balanced": {
        "temperature": 0.85,
        "top_p": 0.92,
        "top_k": 60
      },
      "exploratory": {
        "temperature": 1.05,
        "top_p": 0.96,
        "top_k": 80
      },
      "aggressive": {
        "temperature": 1.3,
        "top_p": 0.99,
        "top_k": 100
      }
    }
  },
  "primary": {
    "is_multimodal": false,
    "requires_mmproj": false,
    "mmproj_path": null
  },
  "webui": {
    "host": "127.0.0.1",
    "port": 7860
  },
  "retrieval": {
    "embed_model": "models/embedding/all-MiniLM-L6-v2",
    "chroma_path": "data/memory_store",
    "collection": "entity_memory",
    "top_k": 5
  },
  "db_path": "data/entity_state.db",
  "qwen3": {
    "temperature": 0.7,
    "top_p": 0.9,
    "max_tokens": 2048,
    "think_token": "/think",
    "no_think_token": "/no_think"
  },
  "identity": {
    "eval_every_n_interactions": 20,
    "stability_threshold": 0.85,
    "naming_requires_stable": 6
  },
  "autonomy_defaults": {
    "perception": true,
    "cognition": true,
    "action": false,
    "initiative": false
  },
  "cognition": {
    "enable_cognition_trace": true,
    "turn_ring_size": 200,
    "reflection_ring_size": 100,
    "state_ring_size": 100,
    "relational_interval_turns": 40,
    "relational_interval_seconds": 1800
  },
  "idle_cognition": {
    "_comment": "Vision mode — same as standard; vision server is perceptual only and doesn't affect idle cognition behaviour.",
    "enabled": true,
    "resting_threshold_hours": 2.0,
    "drifting_threshold_hours": 6.0,
    "deep_threshold_hours": 24.0,
    "resting_fire_prob": 0.25,
    "drifting_fire_prob": 0.5,
    "deep_fire_prob": 0.75,
    "min_gap_hours": 1.5,
    "max_cognitions_per_day": 6,
    "memory_context_count": 6,
    "max_tokens": 180,
    "temperature": 0.82
  },
  "stt": {
    "model_path": "models/stt/ggml-small.en-q8_0.bin",
    "sample_rate": 16000,
    "channels": 1,
    "chunk_ms": 30,
    "silence_ms": 800,
    "language": "en",
    "fw_model": "small.en",
    "fw_device": "cpu",
    "fw_compute": "int8"
  },
  "tts": {
    "binary": "Piper/piper/piper.exe",
    "model_path": "models/tts/en_US-amy-medium.onnx",
    "sample_rate": 22050,
    "speaker_id": 0
  },
  "discord": {
    "enabled": true,
    "credential_file": "AI personal files/Discord.txt",
    "respond_only_to_mentions": true,
    "ignore_bots": true
  },
  "google": {
    "enabled": true,
    "client_secret_path": "config/google/*.json",
    "token_path": "data/google_token.json",
    "calendar_enabled": true,
    "gmail_enabled": true,
    "drive_enabled": true
  },
  "workspace_tools": {
    "_comment": "Sandboxed workspace available to the entity as its persistent file environment.",
    "enabled": true,
    "workspace_root": "data/workspace",
    "allow_delete": false,
    "allow_exec": false
  },
  "worldview": {
    "_comment": "Passive partner orientation subsystem. Sources are processed on demand (never automatically). Receiving a source document requires no acknowledgment. The profile shapes interpretation, not conversational content.",
    "enabled": true,
    "worldview_path": "data/worldview",
    "max_profile_lines_in_prompt": 10
  },
  "backup": {
    "_comment": "Automatic state snapshots. Covers DB, vector memory, workspace, and JSON state files.",
    "backup_path": "data/backups",
    "max_backups": 10,
    "auto_backup_interval_hours": 24
  },
  "computer_use": {
    "_comment": "Supervised computer-use subsystem. Layered access: mode → shortcut allowlist → per-app action policy.",
    "_doc": "Enabling this does NOT grant the entity unrestricted computer access. The entity may only use applications present in approved_shortcuts_path, and only the actions listed in app_policy_path. The operator sets the mode. Halt is always available.",
    "enabled": false,
    "default_mode": "off",
    "approved_shortcuts_path": "data/computer_use/approved_shortcuts",
    "app_policy_path": "data/computer_use/app_policy.json",
    "decision_ring_size": 200,
    "_modes": {
      "off": "No computer use permitted.",
      "command_only": "Approved apps only, for direct user-requested tasks.",
      "supervised_session": "Approved apps with bounded continuation while operator supervises."
    }
  },
  "toolpacks": {
    "_comment": "All packs are loaded into the registry at startup. The admin panel controls which are enabled. Add pack names here to make them available to the entity.",
    "enabled": true,
    "packs": [
      "deterministic_tools",
      "text_tools",
      "diff_tools",
      "event_journal_tools",
      "web_tools",
      "workspace_tools",
      "network_tools",
      "http_diag_tools",
      "fs_tools",
      "git_tools",
      "package_tools",
      "telemetry_tools",
      "ingestion_tools",
      "ca_tools",
      "notifications_tools",
      "google_tools",
      "scheduler_tools",
      "process_tools",
      "recovery_tools",
      "secrets_tools",
      "service_control_tools",
      "system_cmd_tools"
    ],
    "required_packs": [
      "google_tools"
    ],
    "notifications_tools": {
      "discord_credential_file": "AI personal files/Discord.txt"
    }
  },
  "overnight_cycle": {
    "enabled": true,
    "conversation_declare_enabled": true,
    "early_phase_hours": 2.0,
    "deep_phase_start_hours": 2.0,
    "prewake_lead_hours": 1.5,
    "allow_investigations_overnight": true,
    "allow_memory_maintenance_overnight": true,
    "allow_initiative_overnight": true,
    "use_declared_window_as_bias": true,
    "cancel_on_live_return": true,
    "live_override_grace_minutes": 20.0,
    "default_soon_minutes": 30,
    "default_morning_return_hour": 8.0,
    "llm_fallback_enabled": true
  },
  "server_activation": {
    "_comment": "Centralized activation policy for elastic auxiliary servers. The executive keeps baseline services resident and may start auxiliary cognition on demand when posture + resources allow.",
    "startup_baseline_only": true,
    "baseline_roles": [
      "primary",
      "tool",
      "vision"
    ],
    "auxiliary_roles": [
      "thinking",
      "creativity"
    ],
    "active_interaction_grace_seconds": 900,
    "active_mode_threshold": 0.82,
    "idle_mode_threshold": 0.45,
    "resource_thresholds": {
      "min_free_ram_mb": 2048,
      "min_free_vram_mb": 1024,
      "max_cpu_percent": 85,
      "max_gpu_percent": 90,
      "allow_when_metrics_unavailable": true
    },
    "roles": {
      "primary": {
        "residency": "resident",
        "activation_mode": "persistent",
        "idle_timeout_seconds": 300,
        "cooldown_seconds": 90,
        "min_uptime_seconds": 60,
        "role_need_score": 0.7
      },
      "vision": {
        "residency": "resident",
        "activation_mode": "persistent",
        "idle_timeout_seconds": 300,
        "cooldown_seconds": 90,
        "min_uptime_seconds": 60,
        "role_need_score": 0.7
      },
      "tool": {
        "residency": "resident",
        "activation_mode": "persistent",
        "idle_timeout_seconds": 300,
        "cooldown_seconds": 90,
        "min_uptime_seconds": 60,
        "role_need_score": 0.7
      },
      "thinking": {
        "residency": "auxiliary",
        "activation_mode": "on_demand",
        "idle_timeout_seconds": 420,
        "cooldown_seconds": 120,
        "min_uptime_seconds": 90,
        "role_need_score": 0.78
      },
      "creativity": {
        "residency": "auxiliary",
        "activation_mode": "on_demand",
        "idle_timeout_seconds": 420,
        "cooldown_seconds": 120,
        "min_uptime_seconds": 90,
        "role_need_score": 0.74
      }
    }
  }
}
