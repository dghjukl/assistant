{
  "_comment": "EOS Hardened Profile \u2014 locked-down baseline for public/untrusted deployment. All external integrations off. Only safe, read-only toolpacks loaded. No autonomous action or initiative. Operator must explicitly re-enable features after review.",
  "_hardening_notes": [
    "discord.enabled = false \u2014 no outbound Discord messaging without explicit opt-in",
    "google.enabled = false \u2014 no OAuth or Google API access without explicit opt-in",
    "autonomy_defaults.action = false \u2014 entity cannot execute tools autonomously",
    "autonomy_defaults.initiative = false \u2014 entity does not self-initiate tasks",
    "computer_use.enabled = false \u2014 no desktop/GUI access",
    "toolpacks: only deterministic, text, diff, event_journal, workspace (no-delete/no-exec), telemetry, ingestion loaded",
    "workspace_tools.allow_delete = false \u2014 workspace files cannot be deleted",
    "workspace_tools.allow_exec = false \u2014 workspace cannot execute code"
